# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_platform?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production-min-64-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# QR Code Signing
QR_SECRET="your-qr-signing-secret-change-in-production-min-64-chars"

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="restaurant-platform"
MINIO_USE_SSL=false

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Application
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3001"

# Session
SESSION_EXPIRY_HOURS=2
SESSION_MAX_PER_TABLE=5

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
