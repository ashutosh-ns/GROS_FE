# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env and fill in actual values
# =============================================================================

# Database
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/restaurantos
DB_USER=restaurantos
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
QR_SECRET=CHANGE_ME_DIFFERENT_32_CHARS_STRING

# URLs
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Frontend (NEXT_PUBLIC_ prefix = exposed to browser)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=https://api.yourdomain.com

# Optional
PORT=3000
NODE_ENV=production
